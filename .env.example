# Resend — email provider for the /api/contact form.
# Create a key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Sender address. Must be a verified domain on your Resend account,
# or "onboarding@resend.dev" during local testing.
# Format: "Name <email@yourdomain.com>"
CONTACT_FROM="Agency <contact@yourdomain.com>"

# Recipient address(es) that receive the form submissions.
# Comma-separated for multiple recipients.
CONTACT_TO=xxxx@xxxxx.com

